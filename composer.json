{
    "name": "vamischenko/decorators",
    "description": "PSR-7 stream decorators for WhatsApp media encryption and decryption",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Vladislav Mischenko",
            "email": "vamischenko@gmail.com",
            "homepage": "https://github.com/vamischenko"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-openssl": "*",
        "ext-hash": "*",
        "psr/http-message": "^1.1 || ^2.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Vamischenko\\Decorators\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vamischenko\\Decorators\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
